{
  "name": "bookmark-lite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "predev": "prisma generate",
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:extension": "pnpm --filter extension dev",
    "build": "next build",
    "build:with-db-setup": "pnpm run db:migrate:deploy && next build",
    "build:with-db-migrate": "pnpm run db:migrate:deploy && next build",
    "build:extension": "pnpm --filter bookmark-lite-extension build",
    "build:extension:local": "pnpm --filter bookmark-lite-extension build:local",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:init": "node scripts/db-init.mjs",
    "db:setup": "prisma db push --schema prisma/schema.prisma",
    "db:setup:seed": "pnpm run db:setup && pnpm run seed:app-content",
    "db:migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "db:migrate:baseline": "node scripts/prisma-migrate-baseline.mjs",
    "db:export": "node scripts/db-export.mjs",
    "db:import": "node scripts/db-import.mjs",
    "db:roundtrip-test": "node scripts/db-roundtrip-test.mjs",
    "seed:admin-user-data": "prisma db execute --file scripts/seed-admin-user-data.sql --schema prisma/schema.prisma",
    "seed:app-content": "node scripts/seed-data/seed-app-content.mjs",
    "seed:app-content:sql": "node scripts/seed-data/generate-seed-app-content-sql.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "argon2": "^0.44.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "fast-csv": "^5.0.7",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5"
  }
}
